# Keep the Docker build context small and the image clean.
# Only Table_S1.csv and data_analysis_mlp_new.R are needed by the build.

# Version control
.git
.gitignore

# R session / history artefacts
.RData
.Rhistory
.Rproj.user
*.Rproj

# OS cruft
.DS_Store
**/.DS_Store

# Generated results (regenerated inside the container)
output/

# Docs and source variants not needed at build time
README.md
LICENSE
email_to_professor.md
data_analysis_mlp.Rmd
Table_S1.tsv

# CI config
.github/
